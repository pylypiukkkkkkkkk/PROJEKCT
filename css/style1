    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.dish-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
}

.dish-card h3 {
    color: #1565c0;
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
}

.dish-card p {
    color: #777;
}

@media (min-width: 600px) {
    .dishes-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (min-width: 860px) {
    .dishes-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

.gastro-info-box {
    background: linear-gradient(135deg, #c62828 0%, #1565c0 100%);
    color: #ffffff;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    text-align: center;
}

.gastro-info-title {
    font-size: 2rem;
    margin-bottom: 1rem;
}

.gastro-info-text {
    font-size: 1.125rem;
    line-height: 1.8;
}

.footer {
    background: linear-gradient(90deg, #1565c0 0%, #ffffff 50%, #d32f2f 100%);
    border-top: 1px solid #e0e0e0;
    margin-top: 3rem;
    padding: 2rem 0 1rem;
}

.footer-grid {
    display: grid;
    gap: 2rem;
    margin-bottom: 2rem;
}

.footer-col {
    color: #212121;
}

.footer-title {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
}

.footer-text {
    font-size: 0.875rem;
    line-height: 1.7;
}

.footer-links {
    list-style: none;
}

.footer-links li {
    margin-bottom: 0.5rem;
}

.footer-links a {
    font-size: 0.875rem;
    color: #212121;
    transition: color 0.3s ease;
}

.footer-links a:hover {
    color: #1565c0;
}

.footer-bottom {
    border-top: 1px solid rgba(0,0,0,0.1);
    padding-top: 1.5rem;
