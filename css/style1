}

.footer-note {
    color: #555;
    font-size: 0.75rem;
}

@media (min-width: 600px) {
    .footer-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (min-width: 860px) {
    .footer-grid {
        grid-template-columns: repeat(4, 1fr);
    }
    
    .footer-col {
        text-align: left;
    }
}
